# Email agent configuration

# Local dev port (production AgentBase runtime always uses 8080).
PORT=8090

# Default report recipient.
DEFAULT_RECIPIENT=trucnt7@vng.com.vn

# Email transport: "mock" (log only, default) or "smtp" (real send).
EMAIL_TRANSPORT=mock
EMAIL_FROM=zalopay-analytics-agent@vng.com.vn

# SMTP settings — only used when EMAIL_TRANSPORT=smtp.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# LLM used to compose the email body (per requirement: openai/gpt-oss-20b).
EMAIL_USE_LLM=true
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-oss-20b
