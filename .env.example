# Local analytics data source
DATA_SOURCE=parquet
PARQUET_PATH=data/event_log.parquet
MAX_ROWS=100

# Legacy Supabase configuration
# Only used when DATA_SOURCE=supabase.
# Supports either:
# - REST URL: https://your-project.supabase.co
# - Postgres URL: postgresql://user:password@host:5432/postgres
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=event_log
SUPABASE_SELECT=*
UPLOAD_DIR=/tmp/agent_uploads
MAX_UPLOAD_BYTES=15728640
MAX_FILE_CONTEXT_CHARS=12000

# LLM provider configuration
# GreenNode AIP example: LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
AGENTBASE_MEMORY_ID=memory-id
MEMORY_STRATEGY_ID=ltms-id
MEMORY_ACTOR_ID=web-user
SYSTEM_PROMPT_PATH=prompts/system_prompt.md
